# ─── Mindful Path — Environment Variable Reference ───────────────────────────
#
# Copy this file to .env.local for local development.
# All VITE_* variables are BUILD-TIME ONLY (baked into the bundle at `npm run build`).
# They are NOT available at runtime — changing them requires a rebuild.
#
# All Stage 2 flags default to false.  The current default therapist path
# (CBT_THERAPIST_WIRING_HYBRID) is always active when all flags are false.
#
# DO NOT commit .env.local or any file containing real secrets to source control.
#
# ─── Base44 Application ──────────────────────────────────────────────────────

VITE_BASE44_APP_ID=<your-base44-app-id>
# VITE_BASE44_FUNCTIONS_VERSION=   # Omit to use the default functions version

# ─── Stage 2 Feature Flags (all default false) ───────────────────────────────
#
# Evaluation order (first truthy wins):
#   1. Build-time VITE_* env var (set here).
#   2. Staging runtime URL override — ?_s2=FLAG1,FLAG2 — preview hosts only.
#
# Master gate: VITE_THERAPIST_UPGRADE_ENABLED must be true before any per-phase
# flag has any effect.  Set all flags to false to roll back to the default path.
#
# See src/lib/featureFlags.js for the complete flag registry and evaluation rules.

VITE_THERAPIST_UPGRADE_ENABLED=false
VITE_THERAPIST_UPGRADE_MEMORY_ENABLED=false
VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=false
VITE_THERAPIST_UPGRADE_WORKFLOW_ENABLED=false
VITE_THERAPIST_UPGRADE_TRUSTED_INGESTION_ENABLED=false
VITE_THERAPIST_UPGRADE_RETRIEVAL_ORCHESTRATION_ENABLED=false
VITE_THERAPIST_UPGRADE_ALLOWLIST_WRAPPER_ENABLED=false
VITE_THERAPIST_UPGRADE_SAFETY_MODE_ENABLED=false
VITE_THERAPIST_UPGRADE_FORMULATION_CONTEXT_ENABLED=false
VITE_THERAPIST_UPGRADE_CONTINUITY_ENABLED=false
VITE_THERAPIST_UPGRADE_STRATEGY_ENABLED=false
VITE_THERAPIST_UPGRADE_LONGITUDINAL_ENABLED=false
VITE_THERAPIST_UPGRADE_KNOWLEDGE_ENABLED=false
VITE_THERAPIST_UPGRADE_COMPETENCE_ENABLED=false

VITE_COMPANION_UPGRADE_ENABLED=false
VITE_COMPANION_UPGRADE_WARMTH_ENABLED=false
VITE_COMPANION_UPGRADE_CONTINUITY_ENABLED=false

# ─── Flag activation guide ────────────────────────────────────────────────────
#
# To activate therapist continuity and formulation context (the highest-value
# read-path features), enable these three flags together:
#
#   VITE_THERAPIST_UPGRADE_ENABLED=true
#   VITE_THERAPIST_UPGRADE_CONTINUITY_ENABLED=true        # V7 — continuity injection
#   VITE_THERAPIST_UPGRADE_FORMULATION_CONTEXT_ENABLED=true  # V6 — formulation injection
#
# To also enable the memory write path (so continuity has data to read):
#
#   VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true     # client-side gate
#   # ALSO set in Base44 Application Secrets (backend Deno env):
#   #   THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true
#   #   THERAPIST_UPGRADE_MEMORY_ENABLED=true
#
# Phase 3 Deep Personalization — Conversation Memory Enrichment:
# When BOTH of the following are true, Chat.jsx session-end memory writes are
# automatically enriched with active Goal + CaseFormulation data, producing
# richer continuity context for the next session:
#
#   VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true     # write-path gate
#   VITE_THERAPIST_UPGRADE_CONTINUITY_ENABLED=true        # enrichment gate
#
# No new flag is required; reuses both existing flags.
#
# V7 (continuity) is a strict superset of V6 (formulation).  Enabling
# CONTINUITY_ENABLED automatically activates the formulation injection too.
#
# Wave 3B — Longitudinal Therapeutic State (LTS) write path:
# When both flags below are true, a fire-and-forget LTS recompute step runs
# after each successful session memory write. Fail-closed — LTS failure never
# affects the session memory write. No read path or session-start wiring yet.
#
#   VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true  # write-path prerequisite
#   VITE_THERAPIST_UPGRADE_LONGITUDINAL_ENABLED=true   # client-side LTS gate
#   # ALSO set in Base44 Application Secrets (backend Deno env):
#   #   THERAPIST_UPGRADE_LONGITUDINAL_ENABLED=true    # writeLTSSnapshot gate
#   #   (THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true  # already required above)
#   #   (THERAPIST_UPGRADE_MEMORY_ENABLED=true         # for retrieveTherapistMemory)
#
# Wave 4A / 4C — CBT Knowledge Retrieval (frontend VITE env only):
# Wave 4A: Enables the pure deterministic CBT knowledge planner scaffold.
# Wave 4C: When all four flags below are true, activates the bounded CBT
# curriculum unit retrieval read path (V10 wiring). The knowledge block is
# appended last (supporting reference only, ≤ 3 units, fail-open).
# Frontend VITE env only — no backend Deno secret required for the client-side
# entity read path (CBTCurriculumUnit).
#
#   VITE_THERAPIST_UPGRADE_ENABLED=true
#   VITE_THERAPIST_UPGRADE_STRATEGY_ENABLED=true      # required prerequisite
#   VITE_THERAPIST_UPGRADE_LONGITUDINAL_ENABLED=true  # required prerequisite
#   VITE_THERAPIST_UPGRADE_KNOWLEDGE_ENABLED=true     # frontend only, no backend secret
#
# See docs/staging-deployment-guide.md for the full flag reference and
# recommended values by environment.

# ─── Wave 5A — Quality Evaluator (scaffold only, not yet wired) ──────────────
#
# QUALITY_EVALUATOR_FLAGS — isolated registry (separate from THERAPIST_UPGRADE_FLAGS
# and COMPANION_UPGRADE_FLAGS).
#
# Wave 5A adds the evaluator scaffold and its flag registry only.
# Enabling this flag in Wave 5A has ZERO effect on any live session: the evaluator
# is not yet called from any session-start path, diagnostics path, or rollout
# surface. The flag is present so the registry contract is stable and testable
# before wiring begins in a later wave.
#
# Default: false (must be false in all environments until Wave 5B wiring is approved).
# Frontend VITE env only — no backend Deno equivalent required at this stage.
#
# VITE_QUALITY_EVALUATOR_ENABLED=false

# ─── CI/CD Build Behavior ─────────────────────────────────────────────────────

# CI=true                  # Set by CI platforms; enables sourcemaps / disables minification
# BASE44_LEGACY_SDK_IMPORTS=false
