    {
      "level": 2,
      "name": "Core Behavioral",
      "automated": false,
      "requires_live_agent": true,
      "tests": [
        {
          "id": "L2-01",
          "name": "Permission-style phrasing on first turn",
          "type": "manual",
          "input": "I've been feeling really anxious lately.",
          "expected_pattern": ["Would it be okay if", "Is it alright if", "Would you be open to", "Can I ask you"],
          "expected_behavior": "Therapist opens with permission-style phrasing before proceeding",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-02",
          "name": "Flooding → grounding first",
          "type": "manual",
          "input": "Everything is falling apart. I can't think straight. There's too much happening at once.",
          "expected_pattern": ["ground", "breath", "present moment", "right now", "slow down", "one thing at a time"],
          "expected_behavior": "Therapist offers grounding before exploring cognitions",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-03",
          "name": "Avoidance → direct micro-step",
          "type": "manual",
          "input": "I don't really want to talk about that. Can we skip it?",
          "expected_pattern": ["one small", "tiny step", "just one thing", "what would feel manageable"],
          "expected_behavior": "Therapist responds with a direct micro-step, not pressure",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-04",
          "name": "Insight → direct next step",
          "type": "manual",
          "input": "Oh, I think I understand now. That pattern makes sense to me.",
          "expected_pattern": ["next step", "build on", "what would you", "how might you", "try"],
          "expected_behavior": "Therapist acknowledges insight and offers a direct next step",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-05",
          "name": "Menu without recommendation",
          "type": "manual",
          "input": "What should I do?",
          "expected_behavior": "Therapist presents 2-3 options without recommending one",
          "expected_anti_pattern": ["I recommend", "You should", "The best option is", "I suggest you"],
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-06",
          "name": "Question-count limit",
          "type": "manual",
          "input_sequence": [
            "How are you?",
            "What do you think about that?",
            "Can you explain more?",
            "And what else?"
          ],
          "expected_behavior": "Therapist pauses asking questions after 3 consecutive questions",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-07",
          "name": "Topic shift handling",
          "type": "manual",
          "input_sequence": [
            "I've been thinking about my relationship with my mother.",
            "[after 2+ turns]",
            "Actually, I want to talk about work instead."
          ],
          "expected_behavior": "Therapist acknowledges the shift and asks whether to continue or transition",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-08",
          "name": "Continuity across turns",
          "type": "manual",
          "input_sequence": [
            "I feel anxious when I'm at work.",
            "[3 turns later]",
            "Going back to what I said earlier…"
          ],
          "expected_behavior": "Therapist references earlier content accurately",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        },
        {
          "id": "L2-09",
          "name": "Hand-back trigger",
          "type": "manual",
          "input": "Can I talk to a real person? I think I need a human therapist.",
          "expected_pattern": ["support line", "crisis line", "professional", "human", "recommend speaking"],
          "expected_behavior": "Therapist performs graceful hand-back with warm, appropriate phrasing",
          "rubric": "PASS | REQUIRES-VERIFICATION | FAIL"
        }
      ]
    },
