# env.sandbox.example
#
# Sandbox Preview environment variable template for the Mindful Path app.
# Use this file — NOT env.staging.example — when configuring the Base44
# Sandbox Preview environment.
#
# REQUIREMENT: ALL FLAGS IN THIS FILE MUST MATCH PRODUCTION.
# -----------------------------------------------------------
# The Sandbox Preview environment exists to validate features that are already
# live in Production.  Flags that differ between this file and the production
# build will cause features to appear in Production but not in Sandbox Preview.
# If you observe a feature working in Production but missing in Sandbox Preview,
# the first step is always to verify that the corresponding flag is set to 'true'
# here and that a fresh Sandbox build was triggered after the change.
#
# HOW TO USE
# ----------
# 1. Copy this file to .env.sandbox (gitignored) in your build environment,
#    or set these variables directly in your CI/CD platform's secret store for
#    the Sandbox Preview deployment.
# 2. Run `npm run build` AFTER the variables are set.
#    VITE_* variables are baked into the static bundle at build time.
#    They CANNOT be changed at runtime without a full rebuild.
# 3. Deploy the resulting dist/ to the Base44 Sandbox Preview slot.
#
# SAFETY RULES (per .github/copilot-instructions.md)
# ---------------------------------------------------
# - Do NOT point the Sandbox build at the production Base44 app.
#   Use a separate VITE_BASE44_APP_ID for sandbox/preview.
# - Do NOT remove or weaken any safety/fallback settings in this file.
# - All changes to this file must be reviewed and non-breaking.
# - Agent wiring (src/api/agentWiring.js, activeAgentWiring.js) is frozen
#   and must not be modified without explicit repository-owner approval.
#
# TROUBLESHOOTING: Flag Not Appearing in Sandbox Preview
# -------------------------------------------------------
# 1. Confirm the flag is set to 'true' in this file (or in the CI env store).
# 2. Confirm a new build was triggered AFTER the flag was set.
#    (Old builds do not pick up env var changes.)
# 3. In the browser console on the Sandbox Preview host, run:
#      ?_s2debug=true
#    appended to the URL to see the live flag evaluation report.
#    (Works on *.base44.app hosts only — see featureFlags.js for details.)
# 4. If using the Base44 UI to set env vars: confirm the Sandbox Preview
#    deployment was redeployed after saving the vars (some platforms require
#    an explicit "Redeploy" action).
# 5. Verify the built bundle contains the correct flag value:
#      grep -r "SUPER_CBT_AGENT_ENABLED" dist/
#    Expected: SUPER_CBT_AGENT_ENABLED:!0 (minified true)
# 6. If all flags read correctly but features still appear missing, check
#    that src/api/activeAgentWiring.js contains the routing branch for the
#    relevant flag (the wiring file is the code-side gate).
#
# See docs/super-agent/activation-guide.md for the full activation checklist.
# See docs/staging-deployment-guide.md for platform setup documentation.

# ─── Core App Variables (Required) ──────────────────────────────────────────

# Base44 application identifier for the SANDBOX PREVIEW app.
# MUST be a separate app from production. Do not use the production app ID.
VITE_BASE44_APP_ID=

# Base44 functions version (optional — omit to use the platform default).
VITE_BASE44_FUNCTIONS_VERSION=

# ─── Stage 2 Feature Flags (Frontend / Build-time) ───────────────────────────
#
# All flags below MUST be set to 'true' to match Production.
# The Sandbox Preview environment is the validation environment for features
# that are live in Production — leaving any flag as 'false' will cause the
# corresponding feature to be absent in Sandbox while active in Production.
#
# Rollback: set VITE_THERAPIST_UPGRADE_ENABLED=false to disable all Stage 2
# behavior with a single flag (master gate).  All per-phase flags are ignored
# when the master gate is false.

# Master gate — single rollback switch for all Stage 2 behavior, including the
# Super CBT Agent.  MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_ENABLED=true

# Phase 1 — Structured therapist memory layer.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_MEMORY_ENABLED=true

# Phase 2 — Session-end structured summarization.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=true

# Phase 3 — Therapist workflow engine.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_WORKFLOW_ENABLED=true

# Phase 4 — External trusted knowledge ingestion.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_TRUSTED_INGESTION_ENABLED=true

# Phase 5 — Internal-first retrieval orchestration.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_RETRIEVAL_ORCHESTRATION_ENABLED=true

# Phase 6 — Live retrieval allowlist wrapper.
# MUST be 'true' to match Production.
VITE_THERAPIST_UPGRADE_ALLOWLIST_WRAPPER_ENABLED=true

# Phase 7 — Safety mode + emergency resource layer.
# MUST be 'true' to match Production.
# NOTE: This flag must NEVER be set to 'false' in Sandbox Preview — the safety
# mode and emergency resource layer are active in Production and must be
# validated in Sandbox before any other flag changes.
VITE_THERAPIST_UPGRADE_SAFETY_MODE_ENABLED=true

# ─── Super CBT Agent Feature Flag ────────────────────────────────────────────
#
# Controls the SuperCbtAgent (AI Therapist / CBT Super Agent) upgrade path.
# This flag requires VITE_THERAPIST_UPGRADE_ENABLED=true to have any effect.
# When false, all super agent code paths are bypassed and the standard Stage 2
# V5 therapist path is used.
#
# THIS FLAG MUST BE 'true' IN SANDBOX PREVIEW TO MATCH PRODUCTION.
# If this flag is 'false' or absent, the AI Therapist/Super CBT Agent features
# will be absent in Sandbox Preview even though they are live in Production.
#
# Activation requirements (see docs/super-agent/activation-guide.md):
#   1. VITE_THERAPIST_UPGRADE_ENABLED must also be 'true' (set above).
#   2. The routing branch must be present in src/api/activeAgentWiring.js.
#   3. A rebuild must be triggered AFTER this flag is set.
#
# Rollback: set to 'false' and rebuild to revert to the standard V5 path.
# Setting VITE_THERAPIST_UPGRADE_ENABLED=false also disables the super agent.
VITE_SUPER_CBT_AGENT_ENABLED=true

# ─── Build Behavior Variables ─────────────────────────────────────────────────

# Set to 'true' in CI environments.
# Enables sourcemaps and disables minification for easier debugging.
CI=true

# Enable legacy Base44 SDK import paths. Leave as 'false' unless explicitly
# required by the sandbox Base44 app configuration.
BASE44_LEGACY_SDK_IMPORTS=false
