# env.staging.example
#
# Staging environment variable template for the Mindful Path app.
#
# HOW TO USE
# ----------
# 1. Copy this file to .env.staging (gitignored) in your build environment,
#    or set these variables directly in your CI/CD platform's secret store.
# 2. Run `npm run build` after the variables are set.
# 3. VITE_* variables are baked into the static bundle at build time.
#    They CANNOT be changed at runtime without a full rebuild.
#
# SAFETY RULES
# ------------
# - Do NOT enable Stage 2 flags until Phase 9 exit criteria are met.
#   See docs/therapist-upgrade-stage2-plan.md §Phase 9.
# - Do NOT point the staging build at the production Base44 app.
#   Use a separate VITE_BASE44_APP_ID for staging.
# - All Stage 2 flags default to false (current path active) when absent.
#
# See docs/staging-deployment-guide.md for full documentation.

# ─── Core App Variables (Required) ──────────────────────────────────────────

# Base44 application identifier for the STAGING app.
# MUST be a separate app from production. Do not use the production app ID.
VITE_BASE44_APP_ID=

# Base44 functions version (optional — omit to use the platform default).
VITE_BASE44_FUNCTIONS_VERSION=

# ─── Stage 2 Feature Flags (Frontend / Build-time) ───────────────────────────
#
# All flags default to false when absent or set to any value other than 'true'.
# The current default therapist path is always active when all flags are false.
#
# PREPARATION ONLY — do NOT set any of these to 'true' until Phase 9 exit
# criteria are confirmed complete (docs/therapist-upgrade-stage2-plan.md §Phase 9).

# Master gate — single rollback switch for all Stage 2 behavior.
# Set to 'true' only when validating Stage 2 in staging.
VITE_THERAPIST_UPGRADE_ENABLED=false

# Phase 1 — Structured therapist memory layer.
VITE_THERAPIST_UPGRADE_MEMORY_ENABLED=false

# Phase 2 — Session-end structured summarization.
VITE_THERAPIST_UPGRADE_SUMMARIZATION_ENABLED=false

# Phase 3 — Therapist workflow engine.
VITE_THERAPIST_UPGRADE_WORKFLOW_ENABLED=false

# Phase 4 — External trusted knowledge ingestion.
VITE_THERAPIST_UPGRADE_TRUSTED_INGESTION_ENABLED=false

# Phase 5 — Internal-first retrieval orchestration.
VITE_THERAPIST_UPGRADE_RETRIEVAL_ORCHESTRATION_ENABLED=false

# Phase 6 — Live retrieval allowlist wrapper.
VITE_THERAPIST_UPGRADE_ALLOWLIST_WRAPPER_ENABLED=false

# Phase 7 — Safety mode + emergency resource layer.
VITE_THERAPIST_UPGRADE_SAFETY_MODE_ENABLED=false

# Phase 1 Quality Gains — Formulation context injection + Socratic patterns.
# Activates V6 wiring. Required as a prerequisite for V7 (Phase 3).
VITE_THERAPIST_UPGRADE_FORMULATION_CONTEXT_ENABLED=false

# Phase 3 Deep Personalization — Cross-session continuity layer.
# Activates V7 wiring: reads prior therapist memory records and injects a
# structured cross-session continuity block into the session-start payload.
# Requires VITE_THERAPIST_UPGRADE_FORMULATION_CONTEXT_ENABLED=true (V7 supersedes V6).
VITE_THERAPIST_UPGRADE_CONTINUITY_ENABLED=false

# Wave 4A / 4C — CBT Knowledge Retrieval.
# Frontend VITE env only. No backend secret required for the client-side entity
# read path. Wave 4C activates the bounded CBT curriculum unit retrieval when
# STRATEGY_ENABLED + LONGITUDINAL_ENABLED + KNOWLEDGE_ENABLED are all true.
# Knowledge block is appended last (supporting reference, ≤ 3 units, fail-open).
VITE_THERAPIST_UPGRADE_KNOWLEDGE_ENABLED=false

# ─── Companion Upgrade Feature Flags ─────────────────────────────────────────
#
# All companion upgrade flags default to false.
# Set VITE_COMPANION_UPGRADE_ENABLED=true to enable companion upgrade routing.

# Master gate — single rollback switch for all companion upgrade behavior.
VITE_COMPANION_UPGRADE_ENABLED=false

# Phase 2 — Companion warmth and attuned response layer (V1 wiring).
VITE_COMPANION_UPGRADE_WARMTH_ENABLED=false

# Phase 3 — Companion continuity layer (V2 wiring).
# Activates continuity-aware personalised responses grounded in session history.
# Requires VITE_COMPANION_UPGRADE_WARMTH_ENABLED=true (V2 supersedes V1).
VITE_COMPANION_UPGRADE_CONTINUITY_ENABLED=false

# ─── Super CBT Agent Feature Flag ────────────────────────────────────────────
#
# Controls the SuperCbtAgent upgrade path (Tasks 1–6 of the super agent rollout).
# This flag requires VITE_THERAPIST_UPGRADE_ENABLED=true to have any effect.
# When false (or absent), all super agent code paths are bypassed and the
# standard Stage 2 V5 therapist path is used.
#
# ACTIVATION REQUIREMENTS (see docs/super-agent/activation-guide.md):
#   1. VITE_THERAPIST_UPGRADE_ENABLED must also be set to 'true'.
#   2. The routing branch must be present in src/api/activeAgentWiring.js
#      (added in the Task 4 activation PR — requires explicit human approval).
#   3. All Phase 0 pre-activation checks must be complete.
#   4. Repository-owner approval is required before enabling in any environment.
#
# Set to 'true' ONLY in staging (after Phase 0 checklist is complete) and ONLY
# in production after Phases 1–3 gates pass.
# See docs/super-agent-rollout-checklist.md for the full phase-gate checklist.
VITE_SUPER_CBT_AGENT_ENABLED=false

# ─── Build Behavior Variables ─────────────────────────────────────────────────

# Set to 'true' in CI environments.
# Enables sourcemaps and disables minification for easier debugging.
CI=true

# Enable legacy Base44 SDK import paths. Leave as 'false' unless explicitly
# required by the staging Base44 app configuration.
BASE44_LEGACY_SDK_IMPORTS=false
